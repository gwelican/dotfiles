{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "prometheus",
  "provider": {
    "local-llama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "local-llama",
      "options": {
        "baseURL": "http://192.168.1.127:1234/v1"
      },
      "models": {
        "qwen3.5-9b-coding": {
          "id": "qwen3.5-9b-coding",
          "name": "qwen3.5-9b-coding",
          "limit": {
            "context": 262144,
            "output": 4096
          }
        },
        "omni-9b-coding": {
          "id": "omni-9b-coding",
          "name": "omni-9b-coding",
          "limit": {
            "context": 262144,
            "output": 4096
          }
        },
        "omni-9b-high-coding": {
          "id": "omni-9b-high-coding",
          "name": "omni-9b-high-coding",
          "limit": {
            "context": 60000,
            "output": 4096
          }
        },
        "qwen3.5-27b-coding": {
          "id": "qwen3.5-27b-coding",
          "name": "qwen3.5-27b-coding",
          "limit": {
            "context": 60000,
            "output": 4096
          }
        },
        "qwen3.5-27b-thinking": {
          "id": "qwen3.5-27b-thinking",
          "name": "qwen3.5-27b-thinking",
          "limit": {
            "context": 60000,
            "output": 4096
          }
        },
      }
    }
  },
  "plugin": [
    "oh-my-opencode-slim",
    // "opencode-pty",
    // "@knikolov/opencode-plugin-simple-memory",
    "opencode-gemini-auth@latest",
    "@tarquinen/opencode-dcp@latest",
    "openrtk",
  ],
  "agent": {
    "plan": {
      "model": "local-llama/qwen3.5-27b-thinking",
      "disable": false
    },
    "build": {
      "model": "local-llama/omni-9b-coding",
    },
    "general": {
      "disable": false
    }
  },
  "mcp": {
    "n8n-mcp": {
      "type": "local",
      "enabled": true,
      "command": [
        "npx",
        "-y",
        "supergateway",
        "--streamableHttp",
        "https://n8n.gwelican.eu/mcp-server/http",
        "--header",
        "authorization:Bearer {env:N8N_MCP_TOKEN}"
      ]
    },
  }
}
