{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/master/assets/oh-my-opencode.schema.json",
  "agents": {
    "sisyphus-junior": {
      "model": "local-llama/qwen3.5-9b-coding"
    },
    "sisyphus": {
      "model": "opencode-go/kimi-k2.5",
      "variant": "max"
    },
    "explore": {
      "model": "local-llama/qwen3.5-9b-coding"
    },
    "prometheus": {
      "model": "opencode-go/kimi-k2.5"
    },
    "atlas": {
      "model": "local-llama/qwen3.5-9b-coding"
    },
    "hephestus": {
      "model": "local-llama/qwen3.5-9b-coding"
    },
    "oracle": {
      "model": "opencode-go/kimi-k2.5",
      "variant": "high"
    },
    "librarian": {
      "model": "local-llama/qwen3.5-9b-coding"
    },
    "metis": {
      "model": "local-llama/qwen3.5-9b-coding"
    },
    "momus": {
      "model": "local-llama/qwen3.5-9b-coding"
    }
  },
  "model": "local-llama/qwen3.5-9b-coding",
  "tmux": {
    "enabled": true,
    "layout": "main-vertical",
    "main_pane_size": 60,
    "main_pane_min_width": 120,
    "agent_pane_min_width": 40
  },
  "defaultConcurrency": 1,
  "modelFallbacks": [
    "local-llama/qwen3.5-9b-coding"
  ],
  "categories": {
    "small": {
      "model": "local-llama/qwen3.5-9b-coding"
    },
    "medium": {
      "model": "opencode-go/kimi-k2.5"
    },
    "large": {
      "model": "opencode-go/kimi-k2.5"
    }
  }
}
