{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "packageRules": [
  {
      automerge: true,
      automergeType: "branch",
      groupName: "mise tools",
      ignoreTests: true,
      matchDatasources: [
        "github-releases",
        "github-tags",
      ],
      matchPackageNames: [
        "/cli/cli/",
        "/opencode/",
        "/carapace-sh/carapace-bin/",
        "/go-task/task/",
        "/astral-sh/uv/",
        "/jdx/usage/",
        "/junegunn/fzf/",
        "/ajeetdsouza/zoxide/",
        "/jesseduffield/lazygit/",
      ],
      matchUpdateTypes: [
        "patch",
        "minor",
      ],
    },

  ]
  
}
