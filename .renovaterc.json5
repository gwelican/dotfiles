{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "packageRules": [
  {
      automerge: true,
      automergeType: "branch",
      groupName: "mise tools",
      ignoreTests: true,
      matchDatasources: [
        "aqua",
        "github-releases",
        "github-tags",
      ],
      matchPackageNames: [
        "/cli/cli/",
        "/opencode/",
        "/carapace-sh/carapace-bin/",
        "/go-task/task/",
        "/astral-sh/uv/",
        "/jdx/usage/",
        "/junegunn/fzf/",
        "/ajeetdsouza/zoxide/",
        "/jesseduffield/lazygit/",
        "/bat/",
        "/atuinsh/atuin/",
        "/twpayne/chezmoi/",
        "/direnv/direnv/",
        "/rclone/rclone/",
        "/google/yamlfmt/",
        "/ogham/exa/",
        "/numtide/treefmt/",
        "/sharkdp/bat/",
        "/willemer/usage/",
        "/difftastic/",
        "/BurntSushi/ripgrep/",
        "/dust-project/dust/",
        "/the-eden-project/eden/",
        "/mitchellh/starship/",
        "/BurntSushi/fd/",
        "/zede/ez/",
        "/MDefer/fastfetch/",
      ],
      matchUpdateTypes: [
        "patch",
        "minor",
      ],
    },

  ]
  
}
