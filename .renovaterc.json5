{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "packageRules": [
  {
      automerge: true,
      automergeType: "branch",
      groupName: "mise tools",
      ignoreTests: true,
      matchDatasources: [
        "github-releases",
      ],
      matchPackageNames: [
        "/cli/cli/",
        "/opencode",
        "carapace",
        "/go-task/task/",
      ],
      matchUpdateTypes: [
        "patch",
        "minor",
      ],
    },

  ]
  
}
