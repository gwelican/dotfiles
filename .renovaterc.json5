{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "automerge": true,
  "automergeType": "branch",
  "ignoreTests": true,
  "packageRules": [
    {
      "matchUpdateTypes": [
        "patch",
        "minor",
        "major",
      ],
    },
  ]
  
}
